{
  "name": "@sealance-io/dokojs",
  "version": "1.0.2",
  "type": "module",
  "description": "DokoJS CLI - TypeScript toolkit for Aleo blockchain development",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a",
  "bin": {
    "dokojs": "packages/cli/dist/index.js"
  },
  "files": [
    "packages/cli/dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sealance-io/doko-js.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "pnpm lint && pnpm run --r --filter \"./packages/**\" build",
    "build:bundle": "rimraf packages/cli/dist && rollup -c rollup.config.bundle.js && mkdir -p packages/cli/dist/template && cp -r packages/cli/template/* packages/cli/dist/template/ && chmod +x packages/cli/dist/index.js",
    "pkg:publish": "pnpm build && pnpm -r publish --access=public",
    "install:cli": "pnpm --filter cli build:install",
    "lint": "pnpm run --r --filter \"./packages/**\" lint",
    "test": "pnpm run --r --filter \"./test\" test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/fs-extra": "^11.0.2",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^20.19.27",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "copyfiles": "^2.4.1",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-config-standard-with-typescript": "^39.1.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-n": "^16.1.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-promise": "^6.1.1",
    "prettier": "^3.7.4",
    "rimraf": "^5.0.10",
    "rollup": "^4.54.0",
    "test": "^3.3.0",
    "tsc-alias": "^1.8.16",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
